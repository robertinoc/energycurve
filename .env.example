# WorkOS AuthKit
# Local development values should point to WorkOS Staging and localhost.
# Vercel Production should use WorkOS Production and the deployed callback URL.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3010/auth/callback

# Supabase Postgres
# Prefer a dedicated Supabase project for local/dev and another for production.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Configure the default WorkOS Logout URI in the WorkOS dashboard to:
# http://localhost:3010/
